harness_account_id       = "your-harness-account-id"
harness_platform_api_key = "pat.xxxxx"
harness_org_id             = "merck"

create_harness_org      = false

# Default source account is the AWS caller identity when empty.
source_account_id         = ""
default_target_account_id = "123456789012"

# Per-environment overrides in environments.tf:
#   source_account_id, target_account_id, source_eks_cluster_name, source_eks_region

# Optional: assume roles when Terraform runs from a central account
# aws_deploy_assume_role_arns = {
#   source = { dev = "arn:aws:iam::111111111111:role/TerraformDeploy" }
#   target = { dev = "arn:aws:iam::222222222222:role/TerraformDeploy" }
# }

aws_region  = "us-east-1"
aws_profile = "your-aws-sso-profile"

create_aws_iam     = true
create_rbac        = true
create_chaos_guard = false
